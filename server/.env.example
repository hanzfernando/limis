MONGO_URI=mongodb_url
PORT=8000
SERVICE_ACCOUNT_EMAIL=service_account_email
SERVICE_ACCOUNT_PASSWORD=service_account_password
JWT_SECRET=secret_key
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Expo dev server on your machine — used when running on emulator/simulator
EXPO_URL=http://localhost:8081

# Expo dev server reachable over LAN — use your machine's local IP
# Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux) to find it
# Used when running Expo Go on a real device connected to the same Wi-Fi
EXPO_GO_URL=http://192.168.x.x:8081

# Public ngrok tunnel to your Expo dev server
# Use when your phone can't reach your machine via LAN (different network, hotspot, etc.)
# Run: ngrok http 8000
# Restart ngrok = new URL, update this value
EXPO_GO_TUNNEL_URL=https://xxxx-xxxx.ngrok-free.app
